{
	"schemaVersion": 1,
	"id": "${mod_id}",
	"version": "${mod_version}",
	"name": "${mod_name}",
	"description": "A server-side Fabric mod for mining connected veins of blocks.",
	"authors": [
		"brainage04"
	],
	"contact": {
		"homepage": "https://github.com/brainage04/VeinMiner",
		"sources": "https://github.com/brainage04/VeinMiner"
	},
	"license": "MIT",
	"icon": "assets/vein_miner/icon.png",
	"environment": "*",
	"entrypoints": {
		"main": [
			"io.github.brainage04.vein_miner.VeinMiner"
		]
	},
	"mixins": [
		"vein_miner.mixins.json"
	],
	"depends": {
		"fabricloader": ">=${loader_version}",
		"minecraft": "~${minecraft_version}",
		"java": ">=${java_version}",
		"fabric-api": "*"
	},
	"accessWidener": "vein_miner.accesswidener"
